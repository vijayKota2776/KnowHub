# KnowHub Environment Variables
# Copy this file to .env and fill in your values

# ── Server ─────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Database Paths ──────────────────────────────────
SQL_DB_PATH=data/knowhub.db
NOSQL_DATA_DIR=data/nosql
GRAPH_DB_PATH=data/graph.json
VECTOR_DB_PATH=data/vector.json

# ── Rate Limiting ───────────────────────────────────
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX=100

# ── CORS ────────────────────────────────────────────
# Comma-separated origins (use * only in development)
ALLOWED_ORIGINS=*
